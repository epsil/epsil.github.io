{
  "name": "wiki",
  "repository": {
    "type": "git",
    "url": "https://bitbucket.org/epsil/wiki.git"
  },
  "scripts": {
    "start": "npm run server",
    "build": "npm run prettier && npm run webpack && npm run prettier-map",
    "prettier-build": "npm run build",
    "browser": "npm run webpack",
    "webpack": "webpack --mode development",
    "index": "node _assets/js/src/build.js",
    "html": "npm run index",
    "refresh": "npm run index",
    "refresh!": "npm run format && npm run refresh",
    "reindex": "npm run index",
    "rebuild": "npm run prettier && npm run index && npm run build",
    "rebuild!": "npm run rebuild && npm run rebuild",
    "rebuild!!": "npm run reinstall && npm run rebuild!",
    "uninstall": "rm -rf node_modules && git stash push -- node_modules/index.html",
    "uninstall!": "npm run uninstall && rm -f package-lock.json",
    "reinstall": "npm run uninstall! && npm install",
    "clean": "git stash && git clean -d -f -f -x",
    "clean!": "npm run reset && npm run clean",
    "clean!!": "npm run reset! && npm run clean",
    "ds_store": "find . -iname \"*.DS_Store\" -exec git rm {} \\;; find . -iname \"*.directory\" -exec git rm {} \\;; find . -iname \"*er i konflikt*\" -exec git rm {} \\;; find . -iname \"*.DS_Store\" -exec rm {} \\;; find . -iname \"*.directory\" -exec rm {} \\;; find . -iname \"*.log\" -exec rm {} \\;",
    "dotfiles": "npm run ds_store",
    "retest": "npm run clean! && npm install && npm test",
    "compile": "node _assets/js/src/build.js index.md test.html",
    "bundle": "npm run browser && npm run eslint",
    "minify": "uglifyjs js/wiki.js -o js/wiki.js",
    "server": "webpack-dev-server --port 8000",
    "live": "npm run server",
    "http": "npm run server",
    "http2": "webpack-dev-server --port 4567",
    "view": "open http://localhost:8000/",
    "open": "open http://localhost:8000/",
    "append": "sh _assets/bin/append.sh",
    "new": "sh _assets/bin/new.sh",
    "edit": "sh _assets/bin/edit.sh",
    "note": "sh _assets/bin/note.sh",
    "notes": "npm run edit note",
    "export": "sh _assets/bin/export.sh",
    "test": "npm run spec && npm run eslint",
    "prettier": "npm run prettier-js && npm run prettier-json && npm run prettier-css && npm run eslint",
    "prettier-js": "prettier --single-quote --write \"_assets/js/src/**/*.{js,jsx,ts}\"",
    "prettier-js!": "prettier --single-quote --write \"**/*.{js,jsx,ts}\"",
    "prettier-json": "prettier --single-quote --write \"*.json\" && prettier --single-quote --write \"_assets/yml/json/settings.json\"",
    "prettier-json!": "prettier --single-quote --write \"**/*.json\"",
    "prettier-css": "prettier --tab-width 4 --single-quote=false --print-width 80 --write \"_assets/{css,fonts,img}/**/*.css\"",
    "prettier-css!": "prettier --tab-width 4 --single-quote=false --print-width 80 --write \"**/*.css\"",
    "prettier-map": "cp _assets/js/wiki.map _assets/js/wiki.map.json && prettier --single-quote --write _assets/js/wiki.map.json && mv _assets/js/wiki.map.json _assets/js/wiki.map",
    "eslint": "eslint _assets/js/src --ext .js,.jsx",
    "lint": "npm run prettier && npm run eslint",
    "format": "npm run lint",
    "markdownlint": "markdownlint **/index.md",
    "phantom": "mocha-phantomjs _assets/js/test/index.html",
    "spec": "npm run bundle && open _assets/js/test/index.html",
    "standalone": "inliner index.html > standalone.html",
    "commit": "git commit -a -m \"Edited offline\" && git --no-pager status",
    "commit!": "npm run refresh && npm run commit",
    "commit!!": "npm run save",
    "commit!!!": "git --no-pager status && git --no-pager diff && git commit -a -m \"Edited offline\"",
    "comit": "npm run commit",
    "commmit": "npm run commit",
    "commt": "npm run commit",
    "ommit": "npm run commit",
    "omit": "npm run commit",
    "ocmmit": "npm run commit",
    "update": "git --no-pager status && git --no-pager diff && git commit -a -m \"Updated `git status | sed -n '/modified:/ {s/^[[:space:]]*modified:[[:space:]]*//;s/\\.txt$//;s/\\.md$//;s/\\.html$//;s/\\/index$//;p;q;}'`\"",
    "save": "npm run commit && npm run push",
    "amend": "git --no-pager status && git --no-pager diff && git commit -a --amend --no-edit",
    "amend-html": "npm run build && npm run amend",
    "build-amend": "npm run rebuild && npm run amend",
    "reword": "git --no-pager status && git --no-pager diff && git commit -a --amend",
    "reset": "git reset --hard",
    "clear": "git stash clear",
    "reset!": "npm run reset && npm run clear",
    "push": "(npm run commit || true) && git --no-pager status && git push",
    "push!": "git --no-pager status && git pull --rebase && git push",
    "push!!": "git --no-pager status && git push --force",
    "pull": "git --no-pager status && git pull --rebase",
    "compress": "git gc",
    "compress!": "git gc --prune=now",
    "log": "git log -p",
    "gitk": "gitk &",
    "gui": "git gui &",
    "status": "git status",
    "system": "neofetch && git status",
    "grep": "sh _assets/bin/grep.sh",
    "todo": "sh _assets/bin/todo.sh",
    "search": "npm run grep",
    "deploy": "npm run rsync",
    "deploy!": "npm run rsync!",
    "sync": "npm run push && npm run rsync",
    "sync!": "npm run push! && npm run rsync!",
    "rsync": "rsync -av --delete --progress --modify-window=2 --exclude '.git' --exclude 'node_modules' . vegardye@ananke.feralhosting.com:www/vegardye.ananke.feralhosting.com/public_html/wiki",
    "rsync!": "rsync -av --delete --progress . vegardye@ananke.feralhosting.com:www/vegardye.ananke.feralhosting.com/public_html/wiki",
    "docx": "for f in **/index.md; do (cd \"${f%index.md}\" && pwd && pandoc -S -f markdown -t docx -o \"index.docx\" \"index.md\"); done",
    "encrypt": "sh _assets/bin/encrypt.sh",
    "decrypt": "sh _assets/bin/decrypt.sh --gui",
    "decrypt-term": "sh _assets/bin/decrypt.sh",
    "decrypt-terminal": "npm run decrypt-term",
    "reencrypt": "npm run decrypt"
  },
  "dependencies": {
    "@babel/polyfill": "^7.2.5",
    "@babel/register": "^7.0.0",
    "bootstrap": "^3.4.0",
    "circular-json": "^0.5.9",
    "clipboard": "^2.0.4",
    "datatables": "^1.10.18",
    "fast-glob": "^2.2.6",
    "fs": "0.0.1-security",
    "gray-matter": "^4.0.1",
    "html-react-parser": "^0.6.1",
    "isomorphic-fetch": "^2.2.1",
    "jquery": "^3.5.0",
    "js-yaml": "^3.12.2",
    "jsdom": "9.4.1",
    "lodash": "^4.17.10",
    "markdown-it": "^8.4.2",
    "markdown-it-abbr": "^1.0.4",
    "markdown-it-attrs": "^2.3.1",
    "markdown-it-container": "^2.0.0",
    "markdown-it-deflist": "^2.0.3",
    "markdown-it-emoji": "^1.4.0",
    "markdown-it-footnote": "^3.0.1",
    "markdown-it-implicit-figures": "^0.9.0",
    "markdown-it-mathjax": "^2.0.0",
    "markdown-it-prism": "^2.0.1",
    "markdown-it-sub": "^1.0.0",
    "markdown-it-sup": "^1.0.0",
    "markdown-it-task-checkbox": "^1.0.6",
    "md5": "^2.2.1",
    "moment": "^2.22.2",
    "openpgp": "^4.4.3",
    "prismjs": "^1.15.0",
    "react": "^16.3.2",
    "react-bootstrap": "^0.32.1",
    "react-dom": "^16.3.2",
    "react-headroom": "^2.2.4",
    "react-helmet": "^5.2.0",
    "rxjs": "^6.4.0",
    "rxjs-compat": "^6.4.0",
    "string": "^3.3.3",
    "string-similarity": "^1.2.0",
    "tidy-html5": "^0.1.1",
    "typogr": "^0.6.8",
    "urijs": "^1.19.1"
  },
  "devDependencies": {
    "@babel/core": "^7.2.2",
    "@babel/preset-env": "^7.2.3",
    "@babel/preset-react": "^7.0.0",
    "babel-eslint": "^10.0.1",
    "babel-loader": "^8.0.4",
    "css-loader": "^2.1.0",
    "eslint": "^5.11.1",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jsx-a11y": "^6.1.2",
    "eslint-plugin-react": "^7.12.0",
    "file-loader": "^3.0.1",
    "markdownlint": "^0.11.0",
    "markdownlint-cli": "^0.13.0",
    "prettier": "^1.15.3",
    "style-loader": "^0.23.1",
    "url-loader": "^1.1.2",
    "webpack": "^4.28.2",
    "webpack-cli": "^3.1.2",
    "webpack-dev-server": "^3.1.14"
  }
}
